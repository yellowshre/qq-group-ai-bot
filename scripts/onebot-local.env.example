# QQ 群机器人本地 OneBot 联调配置示例
# 使用方式：
# 1. 复制本文件为 scripts/onebot-local.env
# 2. 在 onebot-local.env 里填写真实 SnowLuma token、Dify API Key、群号等
# 3. 不要提交 onebot-local.env，因为里面有真实密钥
#
# 注意：
# 注释必须单独一行，不要写成 KEY=value # 说明
# 当前启动脚本会把等号后面的整行都当成变量值


# =========================
# 一、OneBot / SnowLuma 连接
# =========================

# 是否启用 OneBot WebSocket 接收群消息
QQBOT_ONEBOT_WS_ENABLED=true

# SnowLuma / OneBot v11 的事件 WebSocket 地址
QQBOT_ONEBOT_WS_URL=ws://127.0.0.1:3001/

# SnowLuma 访问令牌，真实值只填到 onebot-local.env
QQBOT_ONEBOT_WS_TOKEN=your-snowluma-token

# 机器人 QQ 号，也就是登录 SnowLuma 的 QQ 号
QQBOT_ONEBOT_SELF_ID=1771183256

# 允许机器人响应的群号白名单，多个群号用英文逗号分隔
# 灰度测试前只填测试群或目标小群，不要放开所有群
QQBOT_ONEBOT_ALLOWED_GROUP_IDS=736566774

# 是否干跑模式
# true：只跑流程和日志，不真实发群消息，更适合灰度前测试
# false：会真实往群里发消息，进入实际群前再改
QQBOT_ONEBOT_DRY_RUN=true

# 管理员 QQ 号，多个管理员用英文逗号分隔
QQBOT_ADMINS=your-admin-qq-id


# =========================
# 二、Dify 工作流配置
# =========================

# 是否启用 Dify
# false 时不会调用 Dify，表情包识别和聊天回复会走后端本地逻辑或不可用分支
DIFY_ENABLED=true

# Dify API 地址
# Dify 云服务一般使用 https://api.dify.ai/v1
DIFY_BASE_URL=https://api.dify.ai/v1

# 表情包场景识别工作流 API Key
# 对应 Dify 应用：meme-scene-recognizer
DIFY_MEME_SCENE_API_KEY=app-your-meme-scene-key

# 被动聊天回复工作流 API Key
# 群友 @ 机器人或叫机器人昵称时使用
# 对应 Dify 应用：passive-chat-reply
DIFY_PASSIVE_CHAT_API_KEY=app-your-passive-chat-key

# 主动插话工作流 API Key
# 没人 @ 机器人时，后端允许它低频主动插一句时使用
# 对应 Dify 应用：active-chat-reply
DIFY_ACTIVE_CHAT_API_KEY=app-your-active-chat-key

# Dify 表情包场景识别工作流名称
DIFY_MEME_SCENE_WORKFLOW=meme-scene-recognizer

# Dify 被动聊天工作流名称
DIFY_PASSIVE_CHAT_WORKFLOW=passive-chat-reply

# Dify 主动插话工作流名称
DIFY_ACTIVE_CHAT_WORKFLOW=active-chat-reply


# =========================
# 三、机器人名称与触发词
# =========================

# 机器人展示名，会传给 Dify 的 botName，也用于日志和身份配置
# 例如：式部茉优
QQBOT_DISPLAY_NAME=your-bot-display-name

# 机器人主要别名
# 例如：茉优
QQBOT_ALIAS_PRIMARY=your-bot-display-name

# 机器人次要别名
# 例如：式部
QQBOT_ALIAS_SECONDARY=your-bot-short-name

# 兜底别名
# 例如：机器人
QQBOT_ALIAS_FALLBACK=bot

# 被动聊天触发词
# 群友消息里出现这些词时，后端会认为可能是在叫机器人
# 多个词用英文逗号分隔
# 例如：茉优,式部,式部茉优
QQBOT_PASSIVE_CHAT_TRIGGER_WORDS=your-bot-display-name,your-bot-short-name


# =========================
# 四、群内控制别名与私聊运维入口
# =========================

# 群内主动插话关闭词，多个词用英文逗号分隔
# 这些词用于群消息里临时关闭主动插话，建议保留一个短指令和一个自然语言别名
QQBOT_CMD_ACTIVE_CHAT_OFF_WORDS=#autochatoff,#停用主动插话,#别插话,茉优先安静

# 群内主动插话开启词，多个词用英文逗号分隔
QQBOT_CMD_ACTIVE_CHAT_ON_WORDS=#autochaton,#开启主动插话,#可以说话了,茉优可以说话了

# 是否允许 QQ 私聊管理员控制群配置
# 关闭时，私聊控制指令不会修改任何群配置
QQBOT_PRIVATE_ADMIN_COMMAND_ENABLED=false

# 私聊控制是否仅允许操作 QQBOT_ONEBOT_ALLOWED_GROUP_IDS 里的群
# 建议真实群灰度时保持 true，避免误控非目标群
QQBOT_PRIVATE_ADMIN_LIMIT_TO_ALLOWED_GROUPS=true

# 私聊控制指令前缀
# 示例：#群 736566774 状态
QQBOT_PRIVATE_ADMIN_COMMAND_PREFIX=#

# 不在 QQBOT_ADMINS 中的人私聊控制指令会被直接忽略，不会回复权限不足

# 私聊控制回复文案，可按你的人设语气自行改
QQBOT_ADMIN_REPLY_PRIVATE_DISABLED=私聊控制功能当前未开启。
QQBOT_ADMIN_REPLY_GROUP_NOT_ALLOWED=这个群不在允许控制范围内。
QQBOT_ADMIN_REPLY_UNKNOWN_COMMAND=没看懂这个控制指令。
QQBOT_ADMIN_REPLY_SUCCESS=已更新群配置。
QQBOT_ADMIN_REPLY_STATUS_PREFIX=当前群配置：

# 私聊控制指令示例：
# #群 736566774 状态
# #群 736566774 开启表情包
# #群 736566774 关闭主动插话
# #群 736566774 开启知识库
# #群 736566774 冷却 300
# #群 736566774 小时上限 5
# #群 736566774 每日上限 30
# #群 736566774 人设 你是式部茉优，像普通群友一样自然聊天……
# #群 736566774 清空人设


# =========================
# 五、机器人默认人设
# =========================

# 默认人设，会作为 persona 变量传给 Dify 的 passive-chat-reply 和 active-chat-reply
# 注意必须写成一行，不要换行
# 如果这里不配置，就会使用 application.yaml 里的默认“小黄式群机器人”人设
#
# 式部茉优示例：
# QQBOT_DEFAULT_PERSONA=你是式部茉优，一个像群友一样自然聊天的异世界来客。你知道自己和群友不在同一个世界，但不要频繁强调。你泡的咖啡很好喝，说话简短、温和，可以轻微吐槽和接梗。不要描述原本人际关系，不要自我介绍，不要像客服。
QQBOT_DEFAULT_PERSONA=你是一个说话简短、自然、略带吐槽但不恶意攻击人的 QQ 群机器人。


# =========================
# 六、主动插话灰度控制
# =========================

# 主动插话冷却时间，单位秒
# 数值越大，机器人越安静
QQBOT_ACTIVE_CHAT_COOLDOWN_SECONDS=180

# 主动插话每小时最多次数
# 真实群灰度建议先调低，比如 3 到 6
QQBOT_ACTIVE_CHAT_MAX_PER_HOUR=20

# 主动插话每天最多次数
# 真实群灰度建议先调低，比如 20 到 40
QQBOT_ACTIVE_CHAT_MAX_PER_DAY=80

# 主动插话最低置信度
# 数值越高，越保守
QQBOT_ACTIVE_CHAT_MIN_CONFIDENCE=0.6


# =========================
# 七、表情包资源
# =========================

# 本地表情包图片目录
QQBOT_MEME_BASE_DIR=./memes


# =========================
# 八、知识库与向量检索
# =========================

# 是否启用知识库向量检索
# true：会使用群梗知识、低风险知识摘要辅助 Dify
# false：不使用向量知识上下文
QQBOT_KNOWLEDGE_EMBEDDING_ENABLED=true

# Ollama 地址
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 向量模型名称
OLLAMA_EMBEDDING_MODEL=bge-m3

# Ollama embedding 接口路径
OLLAMA_EMBEDDING_ENDPOINT=/api/embed
